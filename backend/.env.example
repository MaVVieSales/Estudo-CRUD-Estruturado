# ============================================================
# Variáveis de ambiente - copie para .env e preencha
# Em produção (AWS EC2 + RDS), configure estas variáveis
# diretamente no ambiente ou via AWS Parameter Store
# ============================================================

# Servidor
PORT=3001
NODE_ENV=development

# Banco de Dados (MariaDB / AWS RDS)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=credito_db

# CORS - origens permitidas (separadas por vírgula)
CORS_ORIGIN=http://localhost:3000
